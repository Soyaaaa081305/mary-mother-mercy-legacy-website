<%- include('../partials/public-header', { title }) %>

<section class="page-hero">
  <p class="eyebrow">Nurses and Caregivers Stories</p>
  <h1>Reflections from the staff who serve</h1>
  <p>Stories focus on compassion, teamwork, lessons learned, and daily service while protecting private resident information.</p>
</section>

<section class="card-grid three content-band">
  <% stories.forEach((story) => { %>
    <article class="info-card">
      <% if (story.featured_image_path) { %>
        <img src="<%= story.featured_image_path %>" alt="<%= story.title %>">
      <% } %>
      <p class="meta"><%= helpers.formatDate(story.published_at || story.created_at) %></p>
      <h2><%= story.title %></h2>
      <p class="meta"><%= story.author_name %>, <%= story.author_role %></p>
      <p><%= helpers.excerpt(story.content, 170) %></p>
      <a class="text-link" href="/caregiver-stories/<%= story.story_id %>">Read story</a>
    </article>
  <% }) %>
</section>

<%- include('../partials/public-footer') %>

