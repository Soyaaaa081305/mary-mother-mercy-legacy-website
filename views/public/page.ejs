<%- include('../partials/public-header', { title }) %>

<%- include('../partials/page-hero', { hero }) %>

<section class="reading-section about-copy">
  <% String(page.content || '').split(/\n{2,}/).forEach((paragraph) => { %>
    <% if (paragraph.trim()) { %>
      <p><%- helpers.nl2br(paragraph.trim()) %></p>
    <% } %>
  <% }) %>
</section>

<section class="values-grid about-values">
  <article>
    <h2>Mission</h2>
    <p>Service to the elderly, rejected, forgotten, and abandoned.</p>
  </article>
  <article>
    <h2>Vision</h2>
    <p>We envision a community that nurtures and nourishes the body and soul of one another, thereby forming a group of God’s people who help others attain eternal life.</p>
  </article>
  <article>
    <h2>Core Values</h2>
    <p>Mercy, dignity, patience, faith, service, teamwork, and responsible stewardship.</p>
  </article>
  <article>
    <h2>Services and Care</h2>
    <p>Daily assistance, safe shelter, meals, spiritual encouragement, volunteer coordination, and support from community partners.</p>
  </article>
</section>

<%- include('../partials/public-footer') %>
