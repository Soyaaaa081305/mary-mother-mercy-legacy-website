<%- include('../../partials/admin-header', { title }) %>

<section class="admin-panel">
  <div class="panel-header">
    <h2>Events</h2>
    <a class="btn primary" href="/admin/events/new">Add Event</a>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Date</th>
          <th>Location</th>
          <th>Participants</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% events.forEach((event) => { %>
          <tr>
            <td><%= event.title %></td>
            <td><%= helpers.formatDateTime(event.event_date) %></td>
            <td><%= event.location || '-' %></td>
            <td><%= event.participant_count %></td>
            <td><span class="status <%= event.status.toLowerCase() %>"><%= event.status %></span></td>
            <td class="actions">
              <a class="btn small secondary" href="/admin/events/<%= event.event_id %>/edit">Edit</a>
              <form method="post" action="/admin/events/<%= event.event_id %>/delete" onsubmit="return confirm('Delete this event and participation records?');">
                <button class="btn small danger" type="submit">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="admin-panel">
  <div class="panel-header">
    <h2>Participation Requests</h2>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Event</th>
          <th>Participant</th>
          <th>Organization</th>
          <th>Status</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% participations.forEach((item) => { %>
          <tr>
            <td><%= item.event_title %></td>
            <td>
              <%= item.full_name %>
              <small><%= item.email %></small>
              <small><%= item.phone_number || '' %></small>
            </td>
            <td><%= item.organization || '-' %></td>
            <td><span class="status <%= item.status.toLowerCase() %>"><%= item.status %></span></td>
            <td><%= helpers.formatDateTime(item.created_at) %></td>
            <td class="actions">
              <form method="post" action="/admin/events/participations/<%= item.participation_id %>/status">
                <select name="status">
                  <% ['Pending', 'Confirmed', 'Declined'].forEach((status) => { %>
                    <option value="<%= status %>" <%= item.status === status ? 'selected' : '' %>><%= status %></option>
                  <% }) %>
                </select>
                <button class="btn small secondary" type="submit">Save</button>
              </form>
              <form method="post" action="/admin/events/participations/<%= item.participation_id %>/delete" onsubmit="return confirm('Delete this participation request?');">
                <button class="btn small danger" type="submit">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../../partials/admin-footer') %>

