APP_NAME="Mary Mother of Mercy CMS"
APP_PORT=3000
# Render sets PORT automatically. Leave blank locally unless you need to override it.
PORT=
NODE_ENV=development
SESSION_SECRET=replace-this-with-a-long-random-secret

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mary_mother_cms
# Optional managed MySQL URI. If set, this overrides DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME.
DATABASE_URL=
MYSQL_URL=

# Optional SSL settings for managed MySQL providers such as Aiven.
# Use DB_SSL_CA_PATH=/etc/secrets/aiven-ca.pem on Render if you add the CA as a secret file.
DB_SSL_MODE=
DB_SSL_CA_PATH=
DB_SSL_CA=
DB_SSL_REJECT_UNAUTHORIZED=

# Optional Cloudinary uploads. If blank, uploads stay local in public/uploads.
# CLOUDINARY_URL can replace CLOUDINARY_CLOUD_NAME/CLOUDINARY_API_KEY/CLOUDINARY_API_SECRET.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=mary-mother-cms

# Local: http://localhost:3000
# Ngrok testing: https://your-ngrok-subdomain.ngrok-free.dev
PUBLIC_BASE_URL=http://localhost:3000

# PayMongo test or live secret key. Use test keys while developing.
PAYMONGO_SECRET_KEY=
PAYMONGO_PAYMENT_METHODS=card,gcash,qrph
PAYMONGO_SEND_EMAIL_RECEIPT=true
PAYMONGO_PASS_ON_FEES=false
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_WEBHOOK_MODE=test

# Admin login email OTP through SendGrid.
# Keep disabled until SENDGRID_API_KEY and SENDGRID_FROM_EMAIL are configured.
ADMIN_OTP_ENABLED=false
ADMIN_OTP_EXPIRES_MINUTES=10
ADMIN_OTP_MAX_ATTEMPTS=5
ADMIN_OTP_TRUST_HOURS=12
ADMIN_OTP_TEST_RECIPIENT=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME="Mary Mother CMS"

# Google Maps Embed API key and footer map query.
GOOGLE_MAPS_EMBED_API_KEY=
FOUNDATION_MAP_QUERY=Mary Mother of Mercy Home For the Elderly And Abandoned Foundation Philippines
