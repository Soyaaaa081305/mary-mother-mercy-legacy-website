<%- include('../partials/public-header', { title }) %>

<section class="page-hero">
  <p class="eyebrow">Donation</p>
  <h1><%= heading %></h1>
  <p><%= message %></p>
  <% if (isPaymongoTestMode) { %>
    <div class="test-mode-notice inline">
      <strong>Test mode</strong>
      <span>This PayMongo checkout is for demo/testing only. No real donation payment is collected.</span>
    </div>
  <% } %>
  <% if (reference) { %>
    <p class="meta">Reference number: <%= reference %></p>
  <% } %>
  <a class="btn primary" href="/support">Return to Support</a>
</section>

<%- include('../partials/public-footer') %>
