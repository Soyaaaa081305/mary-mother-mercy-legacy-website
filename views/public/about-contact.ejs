<%- include('../partials/public-header', { title }) %>

<%- include('../partials/page-hero', { hero }) %>

<section class="reading-section about-copy">
  <% String(page.content || '').split(/\n{2,}/).forEach((paragraph) => { %>
    <% if (paragraph.trim()) { %>
      <p><%- helpers.nl2br(paragraph.trim()) %></p>
    <% } %>
  <% }) %>
</section>

<section class="values-grid about-values">
  <article>
    <p class="eyebrow">Mission</p>
    <h2>Providing shelter, care, and compassion</h2>
    <p>To provide a safe, caring, and nurturing environment for abandoned elderly women, offering them shelter, daily support, prayer, companionship, and the dignity of being treated as family.</p>
  </article>
  <article>
    <p class="eyebrow">Vision</p>
    <h2>A home where every elder is valued</h2>
    <p>To be a place of mercy where elderly women who have been forgotten or left behind can experience love, respect, spiritual care, and a peaceful community in their later years.</p>
  </article>
</section>

<section id="contact" class="contact-overview">
  <article class="contact-card official-contact">
    <p class="eyebrow">Official Contact Channels</p>
    <h2>Reach the foundation office</h2>
    <dl>
      <div>
        <dt>Email</dt>
        <dd><%= siteInfo.foundation_email || 'info@marymother.local' %></dd>
      </div>
      <div>
        <dt>Gmail</dt>
        <dd><%= siteInfo.gmail_address || 'marymotherfoundation@gmail.com' %></dd>
      </div>
      <div>
        <dt>Telephone</dt>
        <dd><%= siteInfo.telephone_number || '(02) 0000 0000' %></dd>
      </div>
      <div>
        <dt>Contact Number</dt>
        <dd><%= siteInfo.contact_number || '+63 900 000 0000' %></dd>
      </div>
      <div>
        <dt>Address</dt>
        <dd><%= siteInfo.foundation_address || 'Replace with verified foundation address.' %></dd>
      </div>
    </dl>
    <% if (siteInfo.facebook_url) { %>
      <a class="btn secondary" href="<%= siteInfo.facebook_url %>" target="_blank" rel="noopener">Facebook Page</a>
    <% } %>
  </article>

  <aside class="contact-card">
    <h2>Location Map</h2>
    <iframe class="map-iframe" title="Foundation location map" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="<%= googleMapEmbedSrc %>" allowfullscreen></iframe>
  </aside>
</section>

<section class="content-band">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Foundation Team</p>
      <h2>Contact Persons</h2>
    </div>
  </div>
  <div class="team-grid">
    <% teamMembers.forEach((member) => { %>
      <article class="team-card">
        <img src="<%= member.profile_image_path || '/images/placeholders/team-office.jpg' %>" alt="<%= member.display_name %>">
        <div>
          <h3><%= member.display_name %></h3>
          <p class="meta"><%= member.role_title %></p>
          <% if (member.email) { %><p><%= member.email %></p><% } %>
          <% if (member.phone_number) { %><p><%= member.phone_number %></p><% } %>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="org-chart-section">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Organizational Chart</p>
      <h2>Foundation structure</h2>
    </div>
  </div>
  <div class="org-photo-frame">
    <img src="/images/mary-mother/org-chart-clean.jpg" alt="Photographed organizational chart of Mary Mother of Mercy Home">
  </div>
</section>

<section id="contact-form" class="contact-layout">
  <form class="form-panel" method="post" action="/contact#contact-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% if (errors && errors.length) { %>
      <div class="alert alert-danger">
        <% errors.forEach((error) => { %>
          <p><%= error %></p>
        <% }) %>
      </div>
    <% } %>
    <label>Full Name
      <input type="text" name="full_name" value="<%= form.full_name || '' %>" required>
    </label>
    <label>Email
      <input type="email" name="email" value="<%= form.email || '' %>" required>
    </label>
    <label>Phone Number
      <input type="text" name="phone_number" value="<%= form.phone_number || '' %>">
    </label>
    <label>Subject
      <input type="text" name="subject" value="<%= form.subject || '' %>" required>
    </label>
    <label>Message
      <textarea name="message" rows="7" required><%= form.message || '' %></textarea>
    </label>
    <button class="btn primary" type="submit">Send Message</button>
  </form>

  <aside class="notice-box">
    <h2>Message Review</h2>
    <p>Messages are saved in the CMS for authorized staff to review. For urgent matters, use the official phone or contact number above.</p>
  </aside>
</section>

<%- include('../partials/public-footer') %>
