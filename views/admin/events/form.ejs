<%- include('../../partials/admin-header', { title }) %>

<form class="admin-panel form-grid" method="post" action="<%= action %>" enctype="multipart/form-data">
  <label>Title
    <input type="text" name="title" value="<%= event.title || '' %>" required>
  </label>
  <label>Event Date and Time
    <input type="datetime-local" name="event_date" value="<%= event.event_date ? new Date(event.event_date).toISOString().slice(0, 16) : '' %>">
  </label>
  <label>Location
    <input type="text" name="location" value="<%= event.location || '' %>">
  </label>
  <label>Status
    <select name="status">
      <option value="Published" <%= event.status === 'Published' ? 'selected' : '' %>>Published</option>
      <option value="Draft" <%= event.status !== 'Published' ? 'selected' : '' %>>Draft</option>
    </select>
  </label>
  <label class="full-span">Description
    <textarea name="description" rows="10" required><%= event.description || '' %></textarea>
  </label>
  <label class="full-span">Event Image
    <input type="file" name="image" accept="image/jpeg,image/png,image/webp,image/gif">
  </label>
  <% if (event.image_path) { %>
    <div class="image-preview full-span">
      <img src="<%= event.image_path %>" alt="<%= event.title %>">
      <span>Current image</span>
    </div>
  <% } %>
  <div class="form-actions">
    <button class="btn primary" type="submit">Save Event</button>
    <a class="btn secondary" href="/admin/events">Cancel</a>
  </div>
</form>

<%- include('../../partials/admin-footer') %>

